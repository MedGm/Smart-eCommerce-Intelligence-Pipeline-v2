# Smart eCommerce Intelligence Pipeline — environment template
# Copy to .env and fill as needed.

# ── Scraping ──
SHOPIFY_STORE=https://ruggable.com
WOOCOMMERCE_URL=https://danosseasoning.com
# Shopify Storefront API (optional, token-based):
# SHOPIFY_STOREFRONT_TOKEN=
# WooCommerce REST API v3 (optional, authenticated):
# WOOCOMMERCE_KEY=
# WOOCOMMERCE_SECRET=

# ── LLM (choose one) ──
# Gemini (primary):
# GEMINI_API_KEY=
# OpenAI (alternative):
# OPENAI_API_KEY=
# OPENAI_BASE_URL=   # e.g. for local/open-source endpoint

# ── Paths (defaults work with repo layout) ──
# DATA_DIR=./data

# ── Scraping (tune for rate limits) ──
# SCRAPING_DELAY=0.5
# SCRAPING_TIMEOUT=12
